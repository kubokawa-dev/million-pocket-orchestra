// 個別の予測候補の詳細（アンサンブル予測の内訳）（ナンバーズ3用）
model Numbers3PredictionCandidate {
  id                    Int      @id @default(autoincrement())
  ensemble_prediction_id Int     // 親のアンサンブル予測ID
  rank                  Int      // 順位（1から始まる）
  number                String   // 予測番号（3桁）
  score                 Float    // アンサンブルスコア
  contributing_models   String   // JSON: この番号を予測したモデルのリスト
  created_at            DateTime @default(now())

  @@map("numbers3_prediction_candidates")
  @@index([ensemble_prediction_id])
  @@index([number])
}

// loto6_model_events(id INTEGER PRIMARY KEY AUTOINCREMENT, event_ts TEXT NOT NULL, actual_number TEXT NOT NULL,
// predictions TEXT NOT NULL, hit_exact INTEGER NOT NULL DEFAULT 0, top_match TEXT, max_position_hits INTEGER NOT NULL, notes TEXT)
model Loto6ModelEvent {
