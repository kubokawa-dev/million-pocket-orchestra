{
  "name": "@million-pocket/api-spec",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "tsp compile tsp/main.tsp --emit @typespec/openapi3",
    "watch": "tsp compile tsp/main.tsp --watch --emit @typespec/openapi3",
    "lint": "redocly lint openapi.generated.yaml",
    "bundle": "redocly bundle openapi.generated.yaml -o bundle.yaml",
    "preview": "redocly preview-docs openapi.generated.yaml",
    "generate:mobile": "orval --config orval.config.ts"
  },
  "devDependencies": {
    "@typespec/compiler": "^0.61.0",
    "@typespec/http": "^0.61.0",
    "@typespec/rest": "^0.61.0",
    "@typespec/openapi": "^0.61.0",
    "@typespec/openapi3": "^0.61.0"
  }
}
