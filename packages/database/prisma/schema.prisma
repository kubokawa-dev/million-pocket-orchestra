// Prisma schema for Million Pocket App
// Supabase Auth integration + Lottery predictions

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Auth (Supabase Auth integration)
// ============================================

model User {
  id              String    @id @default(uuid()) // matches Supabase auth.users.id
  email           String    @unique
  username        String?   @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  predictions     Prediction[]
  likes           Like[]
  comments        Comment[]

  @@map("users")
}

// ============================================
// Predictions (User-generated lottery predictions)
// ============================================

model Prediction {
  id              String    @id @default(uuid())
  userId          String
  lotteryType     LotteryType
  
  // Prediction content
  numbers         String    // JSON array of numbers
  bonusNumber     Int?      // For Loto6
  confidence      Float?    // 0.0 - 1.0
  reasoning       String?   // User's explanation
  
  // Target draw
  targetDrawNumber Int?
  targetDrawDate  DateTime?
  
  // Visibility & moderation
  isPublic        Boolean   @default(true)
  isHidden        Boolean   @default(false) // Admin can hide
  flagCount       Int       @default(0)
  
  // Result tracking
  actualDrawNumber Int?
  actualNumbers    String?
  actualBonusNumber Int?
  hitStatus        String?  // exact/partial/miss
  hitCount         Int?
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes           Like[]
  comments        Comment[]

  @@map("predictions")
  @@index([userId])
  @@index([lotteryType])
  @@index([targetDrawNumber])
  @@index([createdAt])
  @@index([isPublic, isHidden])
}

enum LotteryType {
  NUMBERS3
  NUMBERS4
  LOTO6
}

// ============================================
// Social Features
// ============================================

model Like {
  id            String      @id @default(uuid())
  userId        String
  predictionId  String
  createdAt     DateTime    @default(now())
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction    Prediction  @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([userId, predictionId])
  @@map("likes")
  @@index([predictionId])
  @@index([userId])
}

model Comment {
  id            String      @id @default(uuid())
  userId        String
  predictionId  String
  content       String
  isHidden      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction    Prediction  @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@map("comments")
  @@index([predictionId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// Official Draw Results (from Python scripts)
// ============================================

model Numbers3Draw {
  draw_number Int    @id
  draw_date   String
  numbers     String

  @@map("numbers3_draws")
}

model Numbers4Draw {
  draw_number Int    @id
  draw_date   String
  numbers     String

  @@map("numbers4_draws")
}

model Loto6Draw {
  draw_number  Int    @id
  draw_date    String
  numbers      String
  bonus_number Int

  @@map("loto6_draws")
}

// ============================================
// ML Model Events & Training Data
// ============================================

model Numbers4ModelEvent {
  id                Int     @id @default(autoincrement())
  event_ts          String
  actual_number     String
  predictions       String
  hit_exact         Int     @default(0)
  top_match         String?
  max_position_hits Int
  notes             String?

  @@map("numbers4_model_events")
}

model Numbers4PredictionLog {
  id                 Int     @id @default(autoincrement())
  created_at         String
  source             String
  label              String?
  number             String
  target_draw_number Int?

  @@map("numbers4_predictions_log")
  @@index([target_draw_number])
}

model Numbers4EnsemblePrediction {
  id                    Int      @id @default(autoincrement())
  created_at            DateTime @default(now())
  target_draw_number    Int?
  model_updated_at      String?
  model_events_count    Int?
  ensemble_weights      String
  predictions_count     Int
  top_predictions       String
  model_predictions     String
  actual_draw_number    Int?
  actual_numbers        String?
  hit_status            String?
  hit_count             Int?
  notes                 String?

  @@map("numbers4_ensemble_predictions")
  @@index([created_at])
  @@index([target_draw_number])
}

model Numbers4PredictionCandidate {
  id                    Int      @id @default(autoincrement())
  ensemble_prediction_id Int
  rank                  Int
  number                String
  score                 Float
  contributing_models   String
  created_at            DateTime @default(now())

  @@map("numbers4_prediction_candidates")
  @@index([ensemble_prediction_id])
  @@index([number])
}

