// Prisma schema for Million Pocket App
// Supabase Auth integration + Lottery predictions

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Auth (Supabase Auth integration)
// ============================================

model User {
  id              String    @id @default(uuid()) // matches Supabase auth.users.id
  email           String    @unique
  username        String?   @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  predictionPosts PredictionPost[] // ユーザーは複数の予測投稿を持つ
  likes           Like[]
  comments        Comment[]

  @@map("users")
}

// ============================================
// Predictions (User-generated lottery predictions)
// ============================================

// ユーザーによる1回の「予測投稿」
model PredictionPost {
  id        String   @id @default(cuid())
  userId    String   // 投稿したユーザーのID
  drawId    String   // どの回号に対する投稿か
  createdAt DateTime @default(now()) // 投稿日時 (17時締切の判定に使う)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)

  predictions Prediction[] // この投稿に含まれる個別の予測 (最大5つ)
  likes       Like[]
  comments    Comment[]

  @@map("prediction_posts")
  @@index([userId])
  @@index([drawId])
}

// 個別の予測数字
model Prediction {
  id             String @id @default(cuid())
  predictionPostId String // どの投稿に属しているか
  numbers        Json   // 予測した数字の配列例: "[10, 22, 31, 33, 40, 41]"

  predictionPost PredictionPost @relation(fields: [predictionPostId], references: [id], onDelete: Cascade)

  @@map("predictions")
  @@index([predictionPostId])
}

enum LotteryType {
  NUMBERS3
  NUMBERS4
  LOTO6
  BINGO5
  LOTO7
  MINILOTO
}

// ============================================
// Social Features
// ============================================

model Like {
  id               String         @id @default(cuid())
  userId           String
  predictionPostId String
  createdAt        DateTime       @default(now())

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictionPost   PredictionPost @relation(fields: [predictionPostId], references: [id], onDelete: Cascade)

  @@unique([userId, predictionPostId])
  @@map("likes")
  @@index([predictionPostId])
  @@index([userId])
}

model Comment {
  id               String         @id @default(cuid())
  userId           String
  predictionPostId String
  content          String
  isHidden         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictionPost   PredictionPost @relation(fields: [predictionPostId], references: [id], onDelete: Cascade)

  @@map("comments")
  @@index([predictionPostId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// Official Draw Results (from Python scripts)
// ============================================

// 宝くじの「回号」情報
model Draw {
  id             String      @id @default(cuid())
  lotteryType    LotteryType // ロト6, ナンバーズ4, or ナンバーズ3
  drawNumber     Int         // 第xxxx回
  drawDate       DateTime    // 抽選日
  winningNumbers String?     // 当選番号 (結果発表後に更新)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  predictionPosts PredictionPost[] // この回号には多くの予測投稿が紐づく

  @@map("draws")
  @@unique([lotteryType, drawNumber]) // 宝くじの種類と回号の組み合わせはユニーク
}

// ============================================
// ML Model Events & Training Data
// ============================================

model Numbers4ModelEvent {
  id                Int     @id @default(autoincrement())
  event_ts          String
  actual_number     String
  predictions       String
  hit_exact         Int     @default(0)
  top_match         String?
  max_position_hits Int
  notes             String?

  @@map("numbers4_model_events")
}

model Numbers4PredictionLog {
  id                 Int     @id @default(autoincrement())
  created_at         String
  source             String
  label              String?
  number             String
  target_draw_number Int?

  @@map("numbers4_predictions_log")
  @@index([target_draw_number])
}

model Numbers4EnsemblePrediction {
  id                    Int      @id @default(autoincrement())
  created_at            DateTime @default(now())
  target_draw_number    Int?
  model_updated_at      String?
  model_events_count    Int?
  ensemble_weights      String
  predictions_count     Int
  top_predictions       String
  model_predictions     String
  actual_draw_number    Int?
  actual_numbers        String?
  hit_status            String?
  hit_count             Int?
  notes                 String?

  @@map("numbers4_ensemble_predictions")
  @@index([created_at])
  @@index([target_draw_number])
}

model Numbers4PredictionCandidate {
  id                    Int      @id @default(autoincrement())
  ensemble_prediction_id Int
  rank                  Int
  number                String
  score                 Float
  contributing_models   String
  created_at            DateTime @default(now())

  @@map("numbers4_prediction_candidates")
  @@index([ensemble_prediction_id])
  @@index([number])
}

