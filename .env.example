# PostgreSQL connection for Prisma and Python scripts
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/millions?schema=public"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Optional: for production deployment
# DATABASE_URL="postgresql://user:password@prod-host:5432/millions?schema=public"
# NEXT_PUBLIC_API_URL="https://your-domain.com/api"

# Docker Compose variables
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb
POSTGRES_PORT=5432
