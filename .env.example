# =============================================================================
# リポジトリルート用 .env の例（Git に載るテンプレ。実値は .env.local に）
# =============================================================================
#
# ■ どのファイルに書くか
#   - Next.js（apps/web）の画面・API … 原則 `apps/web/.env.local` を使う（詳細は apps/web/.env.example）
#   - ルートの Python / Prisma / その他ツール … ルートの `.env.local`（このファイルをコピーして作成）
#   - ルートの .env.local は .gitignore 対象。コミットしないこと
#
# ■ Vercel
#   Web アプリ用の NEXT_PUBLIC_* / SUPABASE_* は Vercel 上では apps/web 用 Environment Variables に登録。
#   （ルートのこのファイルは主にローカル CLI 用の説明）
#
# ■ GitHub Actions
#   Python 日次パイプライン等は Repository secrets に以下を設定する例あり:
#     NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#     ANTHROPIC_API_KEY（分析ジョブ）
#   各ワークフロー: .github/workflows/*.yml を参照
#
# =============================================================================
# 以下、変数ごとの用途
# =============================================================================

# PostgreSQL（Prisma / 一部 Python。ローカル DB 向け）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/millions?schema=public"

# Supabase — Next（apps/web）では apps/web/.env.local を推奨。
# ルートのツールだけ動かすときはルート .env.local に同じ名前で書いてもよい。
# リモート ref 例: tlpzbqjlcuncmkbfyeyl
NEXT_PUBLIC_SUPABASE_URL="https://tlpzbqjlcuncmkbfyeyl.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Python tools/load_numbers4_csv_to_postgres.py 用（いずれか）
# SUPABASE_DATABASE_URL="postgresql://postgres:...@db.tlpzbqjlcuncmkbfyeyl.supabase.co:5432/postgres?sslmode=require"
# SUPABASE_DB_PASSWORD="your-database-password"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Optional: for production deployment
# DATABASE_URL="postgresql://user:password@prod-host:5432/millions?schema=public"
# NEXT_PUBLIC_API_URL="https://your-domain.com/api"

# Docker Compose variables
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb
POSTGRES_PORT=5432
