# =============================================================================
# Supabase — ローカル OR リモートを .env.local で切り替え（同じ変数名）
# =============================================================================
#
# ■ ローカル（Docker で `npm run supabase:start` 後）
#   キーはターミナルで: npx supabase status
#   または: npx supabase status -o env  （env 形式でコピーしやすい）
#
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status の anon key>
# SUPABASE_SERVICE_ROLE_KEY=<supabase status の service_role key>
#
# ■ リモート（プロジェクト ref: tlpzbqjlcuncmkbfyeyl）
#   Dashboard → Project Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://tlpzbqjlcuncmkbfyeyl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
#
# CLI でリモートと紐付け（別環境で初回のみ）:
#   npx supabase login
#   npx supabase link --project-ref tlpzbqjlcuncmkbfyeyl
#
